# ── Supabase (auth + persistence + real publishing) ───────────────────────
# Leave blank to run in local fallback mode (publish encodes into the URL).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (server only) — used by the Stripe webhook to set user plans.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI generation (optional) ───────────────────────────────────────────────
# If set, /api/generate uses Claude to author a rich scene config.
ANTHROPIC_API_KEY=

# ── Stripe billing (optional) ──────────────────────────────────────────────
# Without these, the pricing buttons show a demo notice. With them, they open
# a real Stripe Checkout. Create one recurring Price per paid plan.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# ── Subdomains (optional) ──────────────────────────────────────────────────
# Set to your apex domain (e.g. voxel.site) once DNS wildcard + host wildcard
# domain are configured. Published sites then live at <slug>.voxel.site.
NEXT_PUBLIC_ROOT_DOMAIN=
